# Docker Compose (repo root) environment variables.
# Copy to `.env` and edit locally. `.env` is ignored by git.
POSTGRES_DB=digital_twin
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me

# Optional: host port for postgres (container always listens on 5432).
# Use 5432 unless it conflicts with local PostgreSQL.
POSTGRES_HOST_PORT=5432
