# PostgreSQL connection string (required).
# Example:
# DT_DB_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@localhost:5432/digital_twin
DT_DB_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@localhost:5432/digital_twin
DT_CORS_ALLOW_ORIGINS=http://localhost:3000

# Optional NASA baseline file path (default: backend/app/ml/nasa_baseline.json)
# DT_NASA_BASELINE_PATH=./app/ml/nasa_baseline.json
#
# Calibration multiplier for comparing device vibration to NASA IMS Bearings baseline (units differ).
# Example: if your device vibration is ~327 and baseline mean is ~0.15 -> 0.15/327 ~= 0.00046
# DT_NASA_VIBRATION_SCALE=0.00046
#
# Z-score thresholds for NASA baseline anomaly (higher = less sensitive)
# - WARNING when z >= DT_NASA_BASELINE_WARN_Z
# - CRITICAL when z >= DT_NASA_BASELINE_CRIT_Z
# DT_NASA_BASELINE_WARN_Z=5
# DT_NASA_BASELINE_CRIT_Z=8
#
# Optional: smooth noisy vibration before NASA comparisons (EMA alpha; 0.1..0.3 typical)
# DT_NASA_VIBRATION_EMA_ALPHA=0.2
#
# Optional: ignore NASA scoring for a short time after PWM changes (seconds)
# Helps avoid CRITICAL->NORMAL flicker caused by transient vibration spikes during speed changes.
# DT_NASA_TRANSIENT_SECONDS=2
#
# Optional: require N consecutive samples above z-threshold before WARNING/CRITICAL
# DT_NASA_BASELINE_CONFIRM_SAMPLES=3

# Optional NASA RUL model (ETA to failure) file path (default: backend/app/ml/nasa_rul_model.json)
# DT_NASA_RUL_MODEL_PATH=./app/ml/nasa_rul_model.json
# Optional ML RUL model (isotonic regression; .joblib). If set and file exists, it has priority over JSON curve.
# DT_NASA_RUL_ML_PATH=./app/ml/nasa_rul_isotonic.joblib
#
# Thresholds for turning NASA RUL into warning/critical (seconds)
# DT_NASA_RUL_WARN_SECONDS=3600
# DT_NASA_RUL_CRIT_SECONDS=600
#
# Optional: keep showing ETA, but don't let NASA RUL change status/score (0=off, 1=on)
# DT_NASA_RUL_AFFECTS_SCORE=1

# Optional ML anomaly detector model (IsolationForest; .joblib)
# DT_NASA_ANOMALY_MODEL_PATH=./app/ml/nasa_anomaly_iforest.joblib
